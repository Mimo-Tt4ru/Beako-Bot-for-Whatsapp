# Onde salvar os arquivos de sessão do WhatsApp
WA_AUTH_DIR=data/auth

# Prefixo de comandos (default: !)
WA_COMMAND_PREFIX=?

# Imprimir QR no terminal (true/false)
WA_PRINT_QR=true

# Nível de log (trace|debug|info|warn|error|fatal)
LOG_LEVEL=info

# URL do Redis para cache quente da sessão/store (opcional)
WA_REDIS_URL=redis://localhost:6378

# Prefixo das chaves do Redis
WA_REDIS_PREFIX=beako:conexao

# URL de conexão MySQL para persistência (opcional)
MYSQL_URL=mysql://user:password@localhost:3306/beako

# Alias legado para MYSQL_URL (opcional)
# WA_DB_URL=mysql://user:password@localhost:3306/beako

# Baixar automaticamente mídias recebidas para disco local (true/false)
WA_MEDIA_AUTO_DOWNLOAD=false

# Diretório base para salvar mídias baixadas
WA_MEDIA_DOWNLOAD_DIR=data/media

# Limite máximo de armazenamento local de mídia (em bytes).
# Exemplo: 10 GB = 10737418240
WA_MEDIA_MAX_BYTES=10737418240

# Retenção de mídias locais em dias.
# Arquivos mais antigos que este limite são removidos automaticamente.
WA_MEDIA_RETENTION_DAYS=7

# Intervalo para retentar MySQL após falha (em ms)
WA_MYSQL_RETRY_MS=60000

# Identificador da conexão quando quiser subir uma única sessão explicitamente.
# Também funciona como fallback legado quando WA_CONNECTION_IDS não estiver definido
# e o boot não encontrar conexões persistidas em auth_creds.
WA_CONNECTION_ID=default

# Lista CSV para subir várias conexões no mesmo processo.
# Tem prioridade sobre WA_CONNECTION_ID.
# Exemplo: WA_CONNECTION_IDS=default,loja1,loja2
# Se ficar vazio e MYSQL_URL estiver configurado, o bootstrap tenta descobrir
# automaticamente as conexões salvas em auth_creds antes de cair no fallback acima.
# WA_CONNECTION_IDS=default,loja1,loja2

# Modo de controle do boot de conexões:
# legacy  = comportamento legado (env/auth_creds/fallback)
# managed = sobe apenas conexões gerenciadas (desired_state=running e enabled=true)
# hybrid  = prioriza managed e importa sessões legadas de auth_creds quando necessário
WA_CONNECTION_CONTROL_MODE=hybrid

# Aceitar mensagens da própria conta (true/false)
WA_ACCEPT_OWN_MESSAGES=false

# Ignorar mensagens do status@broadcast para reduzir ruído de sessão (true/false)
WA_IGNORE_STATUS_BROADCAST=true

# Persistir chaves do Signal também no disco (true/false)
WA_AUTH_PERSIST_KEYS=false

# Ajustes de performance de auth (opcionais)
# Chunk para operacoes em lote de signal_keys no MySQL (default 500)
WA_SIGNAL_KEYS_CHUNK=500
# Concurrency de leitura/escrita em disco para auth (default 50)
WA_AUTH_DISK_CONCURRENCY=50

# Ativar proteção antiban no sendMessage (true/false)
WA_ANTIBAN_ENABLED=false

# Permitir logs internos da lib antiban no console (true/false)
WA_ANTIBAN_LOGGING=false

# Diretório para persistência do warm-up do antiban
WA_ANTIBAN_STATE_DIR=data/antiban

# Intervalo para salvar o estado do antiban em ms
WA_ANTIBAN_STATE_SAVE_MS=300000

# Nível de risco para pausa automática (low|medium|high|critical)
WA_ANTIBAN_AUTO_PAUSE_AT=high

# Limites opcionais do antiban
# WA_ANTIBAN_MAX_PER_MINUTE=1200
# WA_ANTIBAN_MAX_PER_HOUR=36000
# WA_ANTIBAN_MAX_PER_DAY=400000
# WA_ANTIBAN_MIN_DELAY_MS=0
# WA_ANTIBAN_MAX_DELAY_MS=0
# WA_ANTIBAN_NEW_CHAT_DELAY_MS=0
# WA_ANTIBAN_MAX_IDENTICAL_MESSAGES=4000
# WA_ANTIBAN_IDENTICAL_WINDOW_MS=1200000
# WA_ANTIBAN_BURST_ALLOWANCE=400
# WA_ANTIBAN_WARMUP_DAYS=140
# WA_ANTIBAN_WARMUP_DAY1_LIMIT=400
# WA_ANTIBAN_WARMUP_GROWTH_FACTOR=36
# WA_ANTIBAN_INACTIVITY_THRESHOLD_HOURS=1440

# Detector de sessão "surda" (conectada mas sem receber eventos de mensagem)
WA_ANTIBAN_DEAF_SESSION_ENABLED=true
# Tempo sem atividade (ms) para considerar sessão surda (default: 300000 = 5min)
# WA_ANTIBAN_DEAF_SESSION_TIMEOUT_MS=300000
# Uptime mínimo (ms) antes de ativar o detector (default: 120000 = 2min)
# WA_ANTIBAN_DEAF_SESSION_MIN_UPTIME_MS=120000
# Forçar reconexão automática ao detectar sessão surda (true/false)
WA_ANTIBAN_DEAF_SESSION_AUTO_RECONNECT=true

# Mitigação LID/PN do antiban (canonicalização de JID)
WA_ANTIBAN_JID_CANONICALIZER_ENABLED=true
# Forma canônica: pn (recomendado) ou lid
WA_ANTIBAN_LID_CANONICAL=pn
# Limite de mapeamentos em memória (opcional, default da lib: 10000)
# WA_ANTIBAN_LID_MAX_ENTRIES=10000

# Endpoint Prometheus de métricas do antiban (porta separada da health)
WA_ANTIBAN_METRICS_ENABLED=false
# WA_ANTIBAN_METRICS_PORT=9108
# WA_ANTIBAN_METRICS_HOST=0.0.0.0
# WA_ANTIBAN_METRICS_PATH=/metrics

# Timeouts do script de delete-session (em ms)
WA_DELETE_SESSION_TIMEOUT_MS=15000
WA_DELETE_SESSION_REDIS_MAX_MS=60000

# Timeouts internos do socket

# Command processing timeout — kills hung handlers to unblock the queue (0 = disabled)
# WA_COMMAND_TIMEOUT_MS=60000

# Maximum queued messages per chat before dropping (protects memory under backpressure)
# WA_ROUTER_MAX_PENDING_PER_QUEUE=500

# Reconnect backoff (exponential + jitter, attempt 1 = immediate)
# WA_RECONNECT_BASE_DELAY_MS=2500   # base delay for attempt 2 (doubles each attempt)
# WA_RECONNECT_MAX_DELAY_MS=60000   # maximum delay cap
# WA_RECONNECT_MAX_ATTEMPTS=0       # 0 = unlimited retries

# Internal socket timeouts
WA_SHUTDOWN_TIMEOUT_MS=10000
WA_CREDS_DEBOUNCE_MS=1500

# Ajustes de performance do backfill
WA_BACKFILL_LOG_SAMPLE=20
WA_BACKFILL_BATCH_SIZE=500
WA_BACKFILL_GROUP_LOG_EVERY=25
WA_BACKFILL_PARTICIPANT_LOG_EVERY=200
WA_BACKFILL_MESSAGE_LOG_EVERY=1000

# Intervalo do worker de backfill (ms) e modo "rodar uma vez" (true/false)
WA_BACKFILL_INTERVAL_MS=30000
WA_BACKFILL_ONCE=false

# Falhas consecutivas máximas do backfill antes de encerrar (0 = desativado)
WA_BACKFILL_MAX_FAILURES=5
# Espera entre ciclos com falha no backfill (ms)
WA_BACKFILL_FAILURE_BACKOFF_MS=60000

# Newsletter metadata cache/retry tuning
# WA_NEWSLETTER_METADATA_SYNC_TTL_MS=300000
# WA_NEWSLETTER_METADATA_RETRY_TTL_MS=30000
# WA_NEWSLETTER_MEDIA_RETRY_BASE_MS=10000
# WA_NEWSLETTER_MEDIA_RETRY_MAX_ATTEMPTS=5

# Limite de mensagens em cache na memória do store (0 = ilimitado)
# WA_MAX_CACHED_MESSAGES=10000

# Healthcheck HTTP
WA_HEALTH_ENABLED=true
WA_HEALTH_HOST=0.0.0.0
WA_HEALTH_PORT=9109

# API REST de gerenciamento de instâncias
# Habilita o servidor HTTP da API (false por padrão)
WA_API_ENABLED=false
# Controla se este processo faz bootstrap das conexões/sockets em memória.
# Use false no processo dedicado de API/Webhook (PM2: beako-api-webhook).
WA_BOOTSTRAP_CONNECTIONS_ENABLED=true
# Porta do servidor HTTP da API
WA_API_PORT=3000
# Host de bind do servidor HTTP da API
WA_API_HOST=0.0.0.0
# Chave de autenticação — se definida, toda requisição exige: Authorization: Bearer <chave>
# WA_API_KEY=sua-chave-secreta

# Webhook de entrada para controle de conexões (Fase 2)
# Segredo compartilhado para validar HMAC SHA-256 no endpoint POST /webhooks/connections
# WA_WEBHOOK_SHARED_SECRET=troque-este-segredo
# Limite máximo do body em bytes para o webhook de entrada
# WA_WEBHOOK_MAX_BODY_BYTES=262144
# Janela de tolerância de timestamp (ms) para mitigar replay
# WA_WEBHOOK_TIMESTAMP_TOLERANCE_MS=300000

# Callbacks assíncronos do ciclo de conexão (Fase 4)
# Lista CSV de destinos permitidos para entrega de webhook.
# A URL enviada pela API precisa existir exatamente nessa lista.
# Exemplo: WA_WEBHOOK_ALLOWED_TARGETS=https://api.exemplo.com/webhook,https://hooks.exemplo.com/beako
# WA_WEBHOOK_ALLOWED_TARGETS=
# Worker legado de retry para tabela webhook_deliveries
# WA_WEBHOOK_RETRY_ENABLED=true
# Habilita worker/outbox de eventos administrativos
# WA_WEBHOOK_OUTBOX_ENABLED=true
# Quantidade de eventos processados por ciclo do worker
# WA_WEBHOOK_OUTBOX_BATCH_SIZE=50
# Backoff base de retry (ms)
# WA_WEBHOOK_OUTBOX_RETRY_BASE_MS=5000
# Backoff máximo de retry (ms)
# WA_WEBHOOK_OUTBOX_RETRY_MAX_MS=300000
